<?xml version="1.0" encoding="utf-8"?>
<!--
  Model material XML - generated by SEUT on export from the Shader Node Editor.
  SE reads material info from THIS file (not the Blender node tree). The mesh's
  material name must equal Name="ExampleCargo_Colorable" below.
  Channel packing + texconv commands: ../../reference/materials-reference.md.

  Shown here as the reference of what SEUT should produce; in a real mod this is
  embedded alongside the .mwm.
-->
<Model>
  <Material Name="ExampleCargo_Colorable">
    <Parameter Name="Technique">MESH</Parameter>
    <Parameter Name="ColorMetalTexture">Textures\Models\ExampleCargo_Colorable_cm.dds</Parameter>
    <Parameter Name="NormalGlossTexture">Textures\Models\ExampleCargo_Colorable_ng.dds</Parameter>
    <Parameter Name="AddMapsTexture">Textures\Models\ExampleCargo_Colorable_add.dds</Parameter>
  </Material>
</Model>
